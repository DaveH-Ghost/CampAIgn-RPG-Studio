# CampAIgn-RPG-Studio environment variables
# Copy to .env and fill in your values. Never commit .env.

# LLM_PROVIDER=openrouter   # or featherless
# LLM_MAX_INPUT_TOKENS=32768
# LLM_INPUT_WARNING_PERCENT=90
# LLM_CONCURRENT_CALLS=1   # set 0 for one-at-a-time (Featherless Premium + DeepSeek)

# --- OpenRouter ---
# OPENROUTER_API_KEY=sk-or-...
# Model ids are provider-specific. DeepSeek V4 Flash on OpenRouter:
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# --- Featherless ---
# FEATHERLESS_API_KEY=...
# Same model, different id on Featherless (do not reuse the OpenRouter id):
# FEATHERLESS_MODEL=deepseek-ai/DeepSeek-V4-Flash

# Optional Studio hosting (remote players / droplet)
# CAMPAIGN_STUDIO_HOST=127.0.0.1   # use 0.0.0.0 to accept remote connections
# CAMPAIGN_STUDIO_PORT=8765
# CAMPAIGN_STUDIO_PUBLIC_URL=https://campaign.example.com   # join links when behind a proxy
