# Realm-Studio environment variables
# Copy to .env and fill in your values. Never commit .env.

# Required for LLM turns (Run turn ▶)
OPENROUTER_API_KEY=sk-or-...

# Optional — default: deepseek/deepseek-v4-flash
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Optional dev helper — stack objects on one tile for grid UI testing
# REALM_STUDIO_DEV_STACK=1
